<!--pages/userinfo/userinfo.wxml-->
<view class="container">
  <!-- 页面标题 -->
  <view class="page-title">用户信息授权</view>
  
  <!-- 获取手机号的按钮 - 主要操作 -->
  <button 
    open-type="getPhoneNumber" 
    bindgetphonenumber="onGetPhoneNumber"
    type="primary"
    plain="{{false}}"
    hover-class="button-hover"
    style="margin-bottom: 20rpx; width: 80%;">
    微信手机号一键获取
  </button>
  <text style="font-size: 24rpx; color: #999; margin-bottom: 40rpx; display: block;">
    * 用于身份验证和联系
  </text>

  <!-- 获取用户昵称和头像的按钮（推荐方式） -->
  <button 
    type="default" 
    bindtap="onGetUserProfile"
    hover-class="button-hover"
    style="margin-bottom: 40rpx; width: 80%;">
    获取昵称和头像
  </button>

  <!-- 显示区域 - 卡片样式 -->
  <view class="info-card" style="width: 80%; margin-top: 30rpx; padding: 30rpx; background-color: #f8f8f8; border-radius: 16rpx;">
    <view style="font-size: 32rpx; font-weight: bold; margin-bottom: 20rpx; color: #333;">已获取的信息</view>
    
    <!-- 用户信息显示 -->
    <block wx:if="{{userInfo.nickName}}">
      <view style="display: flex; align-items: center; margin-bottom: 20rpx;">
        <image src="{{userInfo.avatarUrl}}" mode="aspectFill" 
               style="width: 80rpx; height: 80rpx; border-radius: 50%; margin-right: 20rpx;"></image>
        <text style="font-size: 28rpx;">昵称：{{userInfo.nickName}}</text>
      </view>
    </block>
    <block wx:else>
      <text style="color: #999; display: block; margin-bottom: 20rpx;">暂未获取昵称和头像</text>
    </block>
    
    <!-- 手机号显示 -->
    <block wx:if="{{phoneNumber}}">
      <view style="display: flex; align-items: center;">
        <text style="font-size: 28rpx;">手机号：{{phoneNumber}}</text>
        <text style="margin-left: 20rpx; font-size: 24rpx; color: #07c160;">已认证</text>
      </view>
    </block>
    <block wx:else>
      <text style="color: #999;">暂未获取手机号</text>
    </block>
  </view>
  
  <!-- 添加操作提示 -->
  <view style="margin-top: 60rpx; font-size: 26rpx; color: #666; text-align: center;">
    <text>点击上方按钮授权后，信息将显示在这里</text>
  </view>
</view>